{
	"appId": "my.cook.flex",
	"appName": "My Cook Flex",
	"webDir": "public",
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 2000,
			"launchAutoHide": true,
			"backgroundColor": "#0a0a0a",
			"showSpinner": true,
			"iosSpinnerStyle": "small",
			"spinnerColor": "#f97316"
		},
		"Keyboard": {
			"resize": "body",
			"style": "dark",
			"resizeOnFullScreen": true
		},
		"FirebaseAuthentication": {
			"skipNativeAuth": false,
			"providers": [
				"google.com"
			]
		},
		"PushNotifications": {
			"presentationOptions": ["badge", "sound", "alert"]
		}
	}
}
