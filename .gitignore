# MCF iOS — .gitignore
# ─────────────────────────────────────────────────────────────

# === Node ===
node_modules/
npm-debug.log*
package-lock.json

# === Xcode ===
xcuserdata/
*.xcscmblueprint
*.xccheckout
App/build/
App/output/
DerivedData/
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
*.hmap
*.ipa

# === Swift Package Manager ===
App/CapApp-SPM/.build/
App/CapApp-SPM/*.resolved
.swiftpm/

# === CocoaPods (au cas où) ===
App/Pods/
App/Podfile.lock

# === Capacitor (auto-généré) ===
capacitor-cordova-ios-plugins/

# === Secrets Apple (NE JAMAIS COMMITER) ===
*.p12
*.mobileprovision
*.p8
certificates/

# === Fichiers système ===
.DS_Store
*.swp
Thumbs.db

# === Logs ===
*.log

# NE PAS ignorer le dossier public/ (contient les fichiers web compilés)
!App/App/public/
