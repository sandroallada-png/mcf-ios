{
	"appId": "my.cook.flex",
	"appName": "My Cook Flex",
	"webDir": "dist",
	"server": {
		"androidScheme": "https",
		"cleartext": true
	},
	"android": {},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 0,
			"launchAutoHide": true,
			"backgroundColor": "#0a0a0a",
			"showSpinner": false
		},
		"FirebaseAuthentication": {
			"skipNativeAuth": false,
			"providers": [
				"google.com"
			]
		}
	},
	"packageClassList": [
		"FirebaseAuthenticationPlugin",
		"AppPlugin"
	]
}
